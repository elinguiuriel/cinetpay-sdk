# CinetPay sandbox credentials
CINETPAY_API_KEY=replace-with-your-account-key
CINETPAY_API_PASSWORD=replace-with-your-account-password
CINETPAY_BASE_URL=https://api.cinetpay.net

# Optional defaults used by scripts/sandbox_cli.py
CINETPAY_SUCCESS_URL=https://example.com/payment/success
CINETPAY_FAILED_URL=https://example.com/payment/failed
CINETPAY_NOTIFY_URL=https://webhook.site/replace-me
CINETPAY_TEST_CLIENT_EMAIL=sandbox@example.com
