{
  "name": "payment_status_retry_after_expired_token",
  "description": "The client should re-authenticate once and retry when the API returns EXPIRED_TOKEN.",
  "reference": "docs/cinetpay-sandbox-contract.md#authentication",
  "responses": [
    {
      "status_code": 200,
      "json_body": {
        "code": 200,
        "status": "OK",
        "access_token": "token-1",
        "token_type": "bearer",
        "expires_in": 86400
      }
    },
    {
      "status_code": 200,
      "json_body": {
        "code": 1003,
        "status": "EXPIRED_TOKEN",
        "message": "Le jeton d'authentification a expire"
      }
    },
    {
      "status_code": 200,
      "json_body": {
        "code": 200,
        "status": "OK",
        "access_token": "token-2",
        "token_type": "bearer",
        "expires_in": 86400
      }
    },
    {
      "status_code": 200,
      "json_body": {
        "code": 100,
        "status": "SUCCESS",
        "merchant_transaction_id": "order-123",
        "transaction_id": "transaction-123",
        "user": {
          "name": "Doe John",
          "email": "john.doe@gmail.com",
          "phone_number": "+2250707000000"
        }
      }
    }
  ],
  "operation": {
    "name": "get_payment_status",
    "identifier": "payment-token"
  },
  "expect": {
    "attrs": {
      "status": "SUCCESS",
      "is_final": true,
      "user.phone_number": "+2250707000000"
    },
    "call_sequence": [
      {
        "method": "POST",
        "path": "/v1/oauth/login"
      },
      {
        "method": "GET",
        "path": "/v1/payment/payment-token",
        "authorization": "Bearer token-1"
      },
      {
        "method": "POST",
        "path": "/v1/oauth/login"
      },
      {
        "method": "GET",
        "path": "/v1/payment/payment-token",
        "authorization": "Bearer token-2"
      }
    ]
  }
}
